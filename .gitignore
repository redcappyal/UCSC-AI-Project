# Secrets — never commit API keys
.env

# Python build/cache junk
__pycache__/
*.pyc

# Tool caches
.matplotlib-cache/
.roboflow-cache/

# App output (uploaded videos, tracking results)
ui_runs/

# Local usage/metrics database
usage.db

.venv/
# Local virtualenv (this checkout uses venv/ not .venv/)
venv/

# Temporary project whitelist: only Python and HTML source files should appear
# as new untracked files.
*
!*/
!*.py
!*.html
!.gitignore
# Agent/design guidelines are durable project docs
!CLAUDE.md
!DESIGN.md
# The distilled eval set is the durable, git-tracked artifact (see
# build_eval_set.py) — ui_runs stays ignored, its distillation doesn't.
!eval_set/*.jsonl
!eval_set/*.json
!eval_set/*.md
# Design specs are durable project docs
!docs/**/*.md
!hardware/README.md
# Printable mount parts + spec PDF: committed so teammates get them without
# regenerating (source of truth stays the generator + markdown)
!hardware/stl/*.stl
!docs/mount-spec.pdf
!docs/figures/*.svg
!bounce_gb_model.pkl
# CI config and the dependency manifests it installs from
!.github/workflows/*.yml
!requirements.txt
!requirements-test.txt
!README.md
# Offline label sets from label_hits.py: the CSV plus the sidecar that says
# which video its frame numbers index into. Small, and the eval set needs them.
# Exact suffix, so scratch copies ("wall_hits copy.csv") stay ignored.
!*wall_hits.csv
!*wall_hits.meta.json
# Native iOS app and deploy artifacts (ios/.gitignore re-excludes the
# generated .xcodeproj and Info.plist)
!ios/**
!deploy/**
# Re-stated after the whitelist above (last match wins): the blanket !ios/**
# and !deploy/** must never make secrets or junk trackable inside those trees.
.env
.DS_Store
__pycache__/
*.pyc
usage.db

# Claude Code worktrees for spawned background tasks (last: must beat the !*.py whitelist)
.claude/worktrees/

# Virtualenvs, re-stated last: the `!*/` above re-includes every directory,
# which silently un-ignored the rules near the top of this file.
.venv/
venv/
