# Secrets — never commit API keys
.env

# Python build/cache junk
__pycache__/
*.pyc

# Tool caches
.matplotlib-cache/
.roboflow-cache/

# App output (uploaded videos, tracking results)
ui_runs/

# Local usage/metrics database
usage.db

.venv/
# Local virtualenv (this checkout uses venv/ not .venv/)
venv/

# Temporary project whitelist: only Python and HTML source files should appear
# as new untracked files.
*
!*/
!*.py
!*.html
!.gitignore
